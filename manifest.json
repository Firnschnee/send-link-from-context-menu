{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "1.4.0",
  "author": "Firnschnee",
  "browser_specific_settings": {
    "gecko": {
      "id": "send-link-from-context-menu@firnschnee",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "mail-16.svg",
    "32": "mail-16.svg",
    "48": "mail-16.svg",
    "96": "mail-16.svg",
    "128": "mail-16.svg"
  },
  "default_locale": "en",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "page_action": {
    "default_title": "__MSG_emailPageLinkContextMenu__",
    "default_icon": "mail-16.svg"
  }
}
